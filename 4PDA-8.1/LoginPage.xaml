<Page
    x:Class="_4PDA.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:_4PDA"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">


    <Grid>
        <ScrollViewer>
            <StackPanel Margin="24,18,24,24" MaxWidth="560" HorizontalAlignment="Left">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="←"
                        Width="46"
                        MinHeight="42"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Click="BackButton_Click" />

                    <Image
                        Grid.Column="1"
                        Source="Assets/4pda_logo.png"
                        Height="42"
                        Width="160"
                        Stretch="Uniform"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center" />
                </Grid>

                <TextBlock
                    Text="вход"
                    FontSize="42"
                    Margin="0,0,0,4" />

                <TextBlock
                    Text="Введите данные аккаунта 4PDA. Пароль не сохраняется. Назад: кнопка сверху, Alt+← или Esc."
                    FontSize="15"
                    Opacity="0.68"
                    TextWrapping="Wrap"
                    Margin="0,0,0,24" />

                <TextBlock
                    Text="логин"
                    FontSize="18"
                    Opacity="0.75"
                    Margin="0,0,0,4" />
                <TextBox
                    x:Name="LoginTextBox"
                    PlaceholderText="ник или e-mail"
                    Margin="0,0,0,14" />

                <TextBlock
                    Text="пароль"
                    FontSize="18"
                    Opacity="0.75"
                    Margin="0,0,0,4" />
                <PasswordBox
                    x:Name="PasswordTextBox"
                    PlaceholderText="пароль"
                    Margin="0,0,0,12" />

                <CheckBox
                    x:Name="HiddenCheckBox"
                    Content="войти скрыто"
                    Margin="0,0,0,18" />

                <Border
                    x:Name="CaptchaPanel"
                    Padding="16"
                    Margin="0,0,0,18"
                    BorderBrush="#3DFFFFFF"
                    BorderThickness="1">
                    <StackPanel>
                        <TextBlock
                            Text="капча"
                            FontSize="24"
                            Margin="0,0,0,10" />

                        <Grid Height="96" Margin="0,0,0,10">
                            <Border Background="#1F000000" />
                            <Image
                                x:Name="CaptchaImage"
                                Stretch="Uniform"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center" />
                            <ProgressRing
                                x:Name="CaptchaProgressRing"
                                Width="48"
                                Height="48"
                                IsActive="False"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock
                            Text="текст с картинки"
                            FontSize="18"
                            Opacity="0.75"
                            Margin="0,0,0,4" />
                        <TextBox
                            x:Name="CaptchaTextBox"
                            PlaceholderText="капча"
                            Margin="0,0,0,10" />

                        <Button
                            Content="обновить капчу"
                            HorizontalAlignment="Stretch"
                            Click="ReloadCaptchaAppBarButton_Click" />
                    </StackPanel>
                </Border>

                <Button
                    x:Name="LoginButton"
                    Content="войти"
                    Height="54"
                    HorizontalAlignment="Stretch"
                    Click="LoginButton_Click" />

                <TextBlock
                    x:Name="StatusTextBlock"
                    FontSize="15"
                    Opacity="0.78"
                    TextWrapping="Wrap"
                    Margin="0,16,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
