<Page
    x:Class="_4PDA.NewsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:_4PDA"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#000000">

    <Grid Background="#000000">
        <ScrollViewer
            x:Name="RootScrollViewer"
            Background="#000000"
            VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="24,18,24,36" Background="#000000" MaxWidth="920" HorizontalAlignment="Left">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="←"
                        Width="46"
                        MinHeight="42"
                        Margin="0,0,12,0"
                        VerticalAlignment="Top"
                        Click="BackButton_Click" />

                    <TextBlock
                        x:Name="TitleTextBlock"
                        Grid.Column="1"
                        FontSize="34"
                        Foreground="#F2F2F2"
                        TextWrapping="Wrap"
                        Margin="0,0,0,8" />
                </Grid>

                <TextBlock
                    x:Name="MetaTextBlock"
                    FontSize="14"
                    Foreground="#9E9E9E"
                    TextWrapping="Wrap"
                    Margin="0,0,0,4" />

                <TextBlock
                    x:Name="SourceTextBlock"
                    FontSize="14"
                    Foreground="#8E8E8E"
                    TextWrapping="Wrap"
                    Margin="0,0,0,16" />

                <StackPanel x:Name="ArticleContentPanel" />

                <TextBlock
                    x:Name="CommentsHeaderTextBlock"
                    Text="Комментарии"
                    FontSize="24"
                    Foreground="#F2F2F2"
                    Margin="0,26,0,10"
                    Visibility="Collapsed" />

                <StackPanel x:Name="CommentsPanel" Background="#000000" HorizontalAlignment="Stretch" />

                <TextBlock
                    x:Name="StatusTextBlock"
                    FontSize="14"
                    Foreground="#8E8E8E"
                    TextWrapping="Wrap"
                    Margin="0,10,0,0" />
            </StackPanel>
        </ScrollViewer>

        <ProgressRing
            x:Name="ProgressRing"
            Width="64"
            Height="64"
            IsActive="False"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />
    </Grid>
</Page>
