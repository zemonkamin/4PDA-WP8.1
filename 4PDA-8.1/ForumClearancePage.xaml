<Page
    x:Class="_4PDA.ForumClearancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF111111" BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1" Padding="12,10,12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="←"
                    Width="46"
                    MinHeight="42"
                    Margin="0,0,12,0"
                    VerticalAlignment="Top"
                    Click="BackButton_Click" />

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Проверка 4PDA" FontSize="28" TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="StatusTextBlock"
                        Text="Дождитесь загрузки страницы, пройдите проверку, затем нажмите «готово»."
                        FontSize="14"
                        Opacity="0.75"
                        TextWrapping="Wrap"
                        Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <WebView
            x:Name="ClearanceWebView"
            Grid.Row="1"
            NavigationCompleted="ClearanceWebView_NavigationCompleted" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,8,12,12">
            <Button Content="обновить" Margin="0,0,8,0" Click="RefreshButton_Click" />
            <Button Content="готово" Click="DoneButton_Click" />
        </StackPanel>
    </Grid>
</Page>
