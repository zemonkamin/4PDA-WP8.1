<Page
    x:Name="pageRoot"
    x:Class="_4PDA.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:_4PDA"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF101010">

    <Page.Resources>
        <CollectionViewSource
            x:Name="groupedItemsViewSource"
            IsSourceGrouped="true"
            ItemsPath="Items" />

        <Style x:Key="SectionGridViewItemStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewItem">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="SectionTileTemplate">
            <Grid
                Width="250"
                Height="92"
                Background="Transparent">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="54" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="{Binding IconText}"
                    FontFamily="Segoe UI Symbol"
                    FontSize="25"
                    Foreground="#FFBEBEBE"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />

                <TextBlock
                    Grid.Column="1"
                    Text="{Binding Title}"
                    FontFamily="Segoe UI Semilight"
                    FontSize="23"
                    Foreground="#FFFFFFFF"
                    Margin="2,0,18,0"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                    MaxLines="2"
                    TextTrimming="WordEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SectionHeaderTemplate">
            <TextBlock
                Text="{Binding Title}"
                FontFamily="Segoe UI Semilight"
                FontSize="34"
                Foreground="#FFFFFFFF"
                Margin="0,0,0,18"
                TextWrapping="NoWrap" />
        </DataTemplate>
    </Page.Resources>

    <Grid Background="#FF101010">
        <Grid.RowDefinitions>
            <RowDefinition Height="122" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="116,0,40,0">
            <TextBlock
                Text="4PDA"
                FontFamily="Segoe UI Light"
                FontSize="58"
                Foreground="#FFFFFFFF"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="0,0,0,20" />
        </Grid>

        <GridView
            x:Name="itemGridView"
            Grid.Row="1"
            Padding="116,18,40,46"
            ItemsSource="{Binding Source={StaticResource groupedItemsViewSource}}"
            ItemTemplate="{StaticResource SectionTileTemplate}"
            ItemContainerStyle="{StaticResource SectionGridViewItemStyle}"
            SelectionMode="None"
            IsSwipeEnabled="False"
            IsItemClickEnabled="True"
            ItemClick="ItemView_ItemClick"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled">

            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid
                        Orientation="Horizontal"
                        MaximumRowsOrColumns="3"
                        GroupPadding="0,0,78,0" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.GroupStyle>
                <GroupStyle HeaderTemplate="{StaticResource SectionHeaderTemplate}" />
            </GridView.GroupStyle>
        </GridView>
    </Grid>
</Page>
